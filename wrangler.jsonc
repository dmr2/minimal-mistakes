{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dj-research",
  "main": "worker.js",
  "compatibility_date": "2026-05-22",
  "assets": {
    "directory": "_site",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    { "pattern": "djrasmussen.co", "custom_domain": true },
    { "pattern": "www.djrasmussen.co", "custom_domain": true }
  ]
}
